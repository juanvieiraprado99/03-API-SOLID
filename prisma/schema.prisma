generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid(7))
  name          String
  email         String    @unique
  password_hash String
  created_at    DateTime  @default(now())
  checkIns      CheckIn[]

  @@map("users")
}

model CheckIn {
  id           String    @id @default(uuid(7))
  created_at   DateTime  @default(now())
  validated_at DateTime?

  user    User   @relation(fields: [user_id], references: [id])
  user_id String

  gym    Gym    @relation(fields: [gym_id], references: [id])
  gym_id String

  @@map("check_ins")
}

model Gym {
  id          String    @id @default(uuid(7))
  title       String
  description String?
  phone       String?
  latitude    Decimal
  longitude   Decimal
  created_at  DateTime  @default(now())
  checkIns    CheckIn[]

  @@map("gyms")
}
